{
  "name": "photo-port",
  "version": "1.0.0",
  "private": true,
  "description": "A React photography portfolio with a category-filtered gallery, lightbox modal, and contact form.",
  "author": "Boyd Roberts",
  "license": "ISC",
  "homepage": "http://coleyrockin.github.io/photo-port",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coleyrockin/photo-port.git"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "react-scripts": "^5.0.1",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^11.2.7",
    "@testing-library/user-event": "^13.5.0",
    "gh-pages": "^4.0.0",
    "prettier": "^3.0.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "format": "prettier --write .",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build"
  },
  "eslintConfig": {
    "extends": ["react-app", "react-app/jest"]
  },
  "browserslist": {
    "production": [">0.2%", "not dead", "not op_mini all"],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
